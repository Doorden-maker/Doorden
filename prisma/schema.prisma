generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  repProfile       RepProfile?
  businessProfile  BusinessProfile?
  sessions         Session[]
  sentMessages     Message[]       @relation("MessageFrom")
  receivedMessages Message[]       @relation("MessageTo")
  notifications    Notification[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RepProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  repCode            String   @unique @default("")
  fullName           String
  phone              String
  city               String   @default("")
  zip                String   @default("")
  serviceAreas       String
  description        String
  trainingLevel      Int      @default(1)
  isActive           Boolean  @default(true)
  avatarUrl          String?
  availabilityStatus String   @default("offline")
  serviceCategories  String   @default("")
  rating             Float    @default(0)
  ratingCount        Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs              Job[]
  trainingPurchases TrainingPurchase[]
  commissions       Commission[]
  applications      JobApplication[]
  trainingProgress  TrainingProgress[]
  partnerships      RepBusinessPartnership[]
}

model BusinessProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  businessName       String
  contactName        String
  phone              String
  businessCity       String   @default("")
  businessZip        String   @default("")
  workingCities      String   @default("")
  serviceAreas       String
  servicesOffered    String
  serviceCategory    String   @default("")
  pricingDescription String
  minRepLevel        Int      @default(1)
  isActive           Boolean  @default(true)
  stripeAccountId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs          Job[]
  opportunities JobOpportunity[]
  partnerships  RepBusinessPartnership[]
}

model RepBusinessPartnership {
  id          String   @id @default(cuid())
  repId       String
  businessId  String
  status      String   @default("pending_rep")
  // pending_rep = rep sent request, waiting for business
  // pending_business = business sent request, waiting for rep
  // accepted
  // rejected
  requestedBy String   @default("rep")
  message     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rep      RepProfile      @relation(fields: [repId], references: [id], onDelete: Cascade)
  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([repId, businessId])
}

model Job {
  id                String    @id @default(cuid())
  leadId            String    @unique @default("")
  referenceNumber   String    @unique @default("")
  repId             String
  businessId        String
  homeownerName     String
  homeownerPhone    String
  homeownerEmail    String    @default("")
  homeownerAddress  String
  serviceType       String
  description       String
  estimatedPrice    Float
  status            String    @default("lead_created")
  repTrainingLevel  Int
  declineReason     String?
  moreInfoRequest   String?
  stripePaymentId   String?
  stripePaymentUrl  String?
  depositAmount     Float?
  homeownerToken    String    @unique @default("")
  visitCode         String?
  visitCodeExpiry   DateTime?
  visitCodeVerified Boolean   @default(false)
  businessDeadline  DateTime?
  scheduledDate     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rep                RepProfile        @relation(fields: [repId], references: [id])
  business           BusinessProfile   @relation(fields: [businessId], references: [id])
  photos             JobPhoto[]
  commission         Commission?
  verification       VerificationCode?
  homeownerMessages  HomeownerMessage[]
}

model HomeownerMessage {
  id        String   @id @default(cuid())
  jobId     String
  fromType  String   // "business" or "homeowner"
  senderName String  @default("")
  content   String
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobPhoto {
  id        String   @id @default(cuid())
  jobId     String
  filename  String
  url       String
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model Commission {
  id          String    @id @default(cuid())
  jobId       String    @unique
  repId       String
  jobValue    Float
  repAmount   Float
  platformFee Float
  businessNet Float
  depositPaid Float
  isPaidOut   Boolean   @default(false)
  paidOutAt   DateTime?
  createdAt   DateTime  @default(now())

  job Job        @relation(fields: [jobId], references: [id])
  rep RepProfile @relation(fields: [repId], references: [id])
}

model TrainingPurchase {
  id              String    @id @default(cuid())
  repId           String
  level           Int
  amount          Float
  stripePaymentId String?
  isConfirmed     Boolean   @default(false)
  confirmedAt     DateTime?
  confirmedBy     String?
  createdAt       DateTime  @default(now())

  rep RepProfile @relation(fields: [repId], references: [id])
}

model TrainingContent {
  id          String   @id @default(cuid())
  level       Int
  title       String
  contentType String
  content     String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress TrainingProgress[]
}

model TrainingProgress {
  id          String   @id @default(cuid())
  repId       String
  contentId   String
  completedAt DateTime @default(now())

  rep     RepProfile      @relation(fields: [repId], references: [id])
  content TrainingContent @relation(fields: [contentId], references: [id])

  @@unique([repId, contentId])
}

model Message {
  id         String   @id @default(cuid())
  fromUserId String
  toUserId   String
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  fromUser User @relation("MessageFrom", fields: [fromUserId], references: [id])
  toUser   User @relation("MessageTo", fields: [toUserId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobOpportunity {
  id                  String   @id @default(cuid())
  businessId          String
  title               String
  description         String
  serviceCategory     String
  territory           String
  commissionStructure String
  minRepLevel         Int      @default(1)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business     BusinessProfile  @relation(fields: [businessId], references: [id])
  applications JobApplication[]
}

model JobApplication {
  id            String   @id @default(cuid())
  opportunityId String
  repId         String
  message       String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity JobOpportunity @relation(fields: [opportunityId], references: [id])
  rep         RepProfile     @relation(fields: [repId], references: [id])

  @@unique([opportunityId, repId])
}

model VerificationCode {
  id                 String    @id @default(cuid())
  jobId              String    @unique
  code               String    @unique
  isVerified         Boolean   @default(false)
  verifiedAt         DateTime?
  homeownerConfirmed Boolean   @default(false)
  createdAt          DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id])
}
